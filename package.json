{
  "name": "retro8-ui",
  "version": "0.1.4",
  "description": "Retro8 UI component library authored with Tailwind CSS and shipped as framework-agnostic CSS and optional JavaScript.",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "retro",
    "8-bit",
    "pixel-art",
    "css",
    "tailwindcss",
    "ui-library",
    "framework-agnostic"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "main": "./dist/retro8.js",
  "style": "./dist/retro8.css",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": "./dist/retro8.js",
    "./retro8.js": "./dist/retro8.js",
    "./retro8.min.js": "./dist/retro8.min.js",
    "./retro8.css": "./dist/retro8.css",
    "./retro8.min.css": "./dist/retro8.min.css",
    "./package.json": "./package.json"
  },
  "scripts": {
    "clean": "rm -rf dist/*",
    "build:css": "postcss src/styles/index.css -o dist/retro8.css",
    "build:css:min": "postcss src/styles/index.css -o dist/retro8.min.css --env production",
    "build:js": "node scripts/build-js.mjs",
    "build": "npm run clean && npm run build:css && npm run build:css:min && npm run build:js",
    "dev:css": "postcss src/styles/index.css -o dist/retro8.css --watch",
    "dev:js": "node scripts/build-js.mjs --watch",
    "dev:docs": "npm --prefix docs-site run dev",
    "dev": "npm run build:css && npm run build:js && npm-run-all --parallel dev:css dev:js dev:docs",
    "build:docs": "npm run build && npm --prefix docs-site run generate",
    "preview": "npm run build:docs && npm --prefix docs-site run preview"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.19",
    "cssnano": "^6.1.2",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.4.38",
    "postcss-cli": "^10.1.0",
    "postcss-import": "^16.1.0",
    "tailwindcss": "^3.4.13",
    "terser": "^5.39.2"
  }
}
