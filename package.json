{
  "name": "retro8-ui",
  "version": "0.1.0",
  "description": "Retro 8-bit UI component library authored with Tailwind CSS and shipped as framework-agnostic CSS.",
  "license": "MIT",
  "keywords": [
    "retro",
    "8-bit",
    "pixel-art",
    "css",
    "tailwindcss",
    "ui-library",
    "framework-agnostic"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "style": "./dist/retro8.css",
  "files": [
    "dist",
    "docs",
    "examples",
    "README.md"
  ],
  "exports": {
    "./retro8.css": "./dist/retro8.css",
    "./retro8.min.css": "./dist/retro8.min.css",
    "./package.json": "./package.json"
  },
  "scripts": {
    "clean": "rm -rf dist/*",
    "build:css": "postcss src/styles/index.css -o dist/retro8.css",
    "build:css:min": "postcss src/styles/index.css -o dist/retro8.min.css --env production",
    "build": "npm run clean && npm run build:css && npm run build:css:min",
    "prepare:playground": "node playground/generate-pages.mjs",
    "dev:css": "postcss src/styles/index.css -o dist/retro8.css --watch",
    "dev:playground": "npm run prepare:playground && vite --config playground/vite.config.mjs",
    "dev": "npm-run-all --parallel dev:css dev:playground",
    "build:playground": "npm run build && npm run prepare:playground && vite build --config playground/vite.config.mjs",
    "preview": "npm run build:playground && vite preview --config playground/vite.config.mjs"
  },
  "devDependencies": {
    "@fontsource/press-start-2p": "^5.2.7",
    "autoprefixer": "^10.4.19",
    "cssnano": "^6.1.2",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.4.38",
    "postcss-cli": "^10.1.0",
    "postcss-import": "^16.1.0",
    "tailwindcss": "^3.4.13",
    "vite": "^5.4.8"
  }
}
